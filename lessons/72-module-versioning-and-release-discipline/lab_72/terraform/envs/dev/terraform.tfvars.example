aws_region   = "eu-west-1"
project_name = "lab72-dev"
environment  = "dev"

vpc_cidr             = "10.71.0.0/16"
public_subnet_cidrs  = ["10.71.1.0/24", "10.71.2.0/24"]
private_subnet_cidrs = ["10.71.11.0/24", "10.71.12.0/24"]

enable_ssm_vpc_endpoints = true
enable_web_ssm           = true

web_ami_id       = "ami-REPLACE_WITH_WEB_AMI"
ssm_proxy_ami_id = "ami-REPLACE_WITH_SSM_PROXY_AMI"

web_min_size         = 1
web_desired_capacity = 1
web_max_size         = 2

asg_min_healthy_percentage     = 50
asg_instance_warmup_seconds    = 120
asg_checkpoint_delay_seconds   = 180
tg_slow_start_seconds          = 60
health_check_healthy_threshold = 2
instance_type_web              = "t3.micro"

github_owner             = "REPLACE_WITH_GITHUB_OWNER"
github_repo              = "REPLACE_WITH_GITHUB_REPO"
github_branch            = "main"
github_apply_environment = "terraform-dev"

# Prefer passing an existing account-level GitHub OIDC provider ARN for all envs.
# Leave empty only if this environment intentionally creates the provider first.
github_oidc_provider_arn = ""

tf_state_bucket_name = "REPLACE_WITH_TFSTATE_BUCKET"
tf_state_key         = "lab72/dev/full/terraform.tfstate"

demo_api_token_parameter_name = "/devops/lab72/dev/demo/api-token"
demo_app_secret_name          = "/devops/lab72/dev/demo/app-secret"

common_tags = {
  Owner       = "DevOpsTrack"
  Criticality = "low"
}
